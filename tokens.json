{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "LINKS Design System tokens — W3C Design Tokens Community Group format. Mirrors styles.css; styles.css is the runtime source of truth.",
  "color": {
    "portal": {
      "student":      { "$value": "#6D28D9", "$type": "color", "$description": "Primary brand violet — student portal" },
      "student-deep": { "$value": "#5B21B6", "$type": "color" },
      "student-ink":  { "$value": "#4C1D95", "$type": "color" },
      "student-50":   { "$value": "#F5F3FF", "$type": "color" },
      "student-100":  { "$value": "#EDE9FE", "$type": "color" },
      "student-200":  { "$value": "#DDD6FE", "$type": "color" },
      "student-300":  { "$value": "#C4B5FD", "$type": "color" },
      "instructor":   { "$value": "#153A5B", "$type": "color" },
      "admin":        { "$value": "#1E6F8C", "$type": "color" },
      "parent":       { "$value": "#2E9B62", "$type": "color" },
      "services":     { "$value": "#E07A2D", "$type": "color" },
      "public":       { "$value": "#C0392B", "$type": "color" }
    },
    "semantic": {
      "success":      { "$value": "{color.portal.parent}",   "$type": "color" },
      "warning":      { "$value": "{color.portal.services}", "$type": "color" },
      "error":        { "$value": "{color.portal.public}",   "$type": "color" },
      "success-soft": { "$value": "#E8F4EE", "$type": "color" },
      "warning-soft": { "$value": "#FBEFE2", "$type": "color" },
      "error-soft":   { "$value": "#F7E2DF", "$type": "color" }
    },
    "neutral": {
      "ink":    { "$value": "#0F172A", "$type": "color" },
      "slate":  { "$value": "#334155", "$type": "color" },
      "stone":  { "$value": "#64748B", "$type": "color" },
      "silver": { "$value": "#94A3B8", "$type": "color" },
      "mist":   { "$value": "#E2E8F0", "$type": "color" },
      "bone":   { "$value": "#F1F5F9", "$type": "color" },
      "paper":  { "$value": "#FFFFFF", "$type": "color" }
    },
    "surface": {
      "default": { "$value": "#F7F6FB", "$type": "color", "$description": "Body wash — cool lavender-grey" },
      "quiet":   { "$value": "#F4F4F8", "$type": "color" }
    }
  },
  "radius": {
    "sm": { "$value": "10px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension", "$description": "Default card radius" },
    "lg": { "$value": "22px", "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },
  "font": {
    "display": { "$value": "Poppins, ui-sans-serif, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
    "ui":      { "$value": "Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif", "$type": "fontFamily" }
  },
  "type": {
    "h1":      { "$value": { "fontFamily": "{font.display}", "fontWeight": 600, "fontSize": "28px", "lineHeight": 1.15, "letterSpacing": "-0.02em" }, "$type": "typography" },
    "h2":      { "$value": { "fontFamily": "{font.display}", "fontWeight": 600, "fontSize": "20px", "lineHeight": 1.2,  "letterSpacing": "-0.01em" }, "$type": "typography" },
    "h3":      { "$value": { "fontFamily": "{font.ui}",      "fontWeight": 600, "fontSize": "15px", "lineHeight": 1.3,  "letterSpacing": "-0.005em" }, "$type": "typography" },
    "body":    { "$value": { "fontFamily": "{font.ui}",      "fontWeight": 400, "fontSize": "14px", "lineHeight": 1.55 }, "$type": "typography" },
    "caption": { "$value": { "fontFamily": "{font.ui}",      "fontWeight": 400, "fontSize": "12px", "lineHeight": 1.4 },  "$type": "typography" },
    "eyebrow": { "$value": { "fontFamily": "{font.ui}",      "fontWeight": 600, "fontSize": "11px", "lineHeight": 1.2, "letterSpacing": "0.08em", "textTransform": "uppercase" }, "$type": "typography" }
  },
  "density": {
    "default": {
      "row-h":      { "$value": "44px", "$type": "dimension" },
      "pad-card":   { "$value": "24px", "$type": "dimension" },
      "pad-card-y": { "$value": "20px", "$type": "dimension" }
    },
    "compact": {
      "row-h":      { "$value": "36px", "$type": "dimension" },
      "pad-card":   { "$value": "18px", "$type": "dimension" },
      "pad-card-y": { "$value": "14px", "$type": "dimension" }
    }
  },
  "shadow": {
    "1":       { "$value": "0 1px 2px rgba(15, 23, 42, 0.04)", "$type": "shadow" },
    "card":    { "$value": "0 1px 3px rgba(15,23,42,0.06), 0 10px 24px -6px rgba(15,23,42,0.14), 0 24px 48px -16px rgba(15,23,42,0.10)", "$type": "shadow" },
    "card-lg": { "$value": "0 2px 6px rgba(15,23,42,0.08), 0 18px 40px -10px rgba(15,23,42,0.18), 0 32px 64px -20px rgba(15,23,42,0.12)", "$type": "shadow" },
    "pop":     { "$value": "0 12px 32px -8px rgba(15, 23, 42, 0.20), 0 2px 6px rgba(15,23,42,0.08)", "$type": "shadow" }
  },
  "motion": {
    "fast":   { "$value": "120ms cubic-bezier(0.4, 0, 0.2, 1)", "$type": "transition" },
    "medium": { "$value": "240ms cubic-bezier(0.4, 0, 0.2, 1)", "$type": "transition" },
    "slow":   { "$value": "360ms cubic-bezier(0.4, 0, 0.2, 1)", "$type": "transition" }
  }
}
